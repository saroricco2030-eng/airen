# ===========================================
# Airen - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values
# cp .env.example .env.local

# -------------------------------------------
# Sentry (Error Tracking)
# https://sentry.io → Settings → Projects → Client Keys
# -------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# -------------------------------------------
# NOTE: AI API Keys
# -------------------------------------------
# AI provider API keys (OpenAI, Anthropic, Google, etc.) are
# stored in the user's browser localStorage, NOT as env vars.
# They are sent per-request to /api/chat and discarded after use.
# No server-side AI API keys are needed.
